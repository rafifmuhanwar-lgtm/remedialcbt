rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is a teacher
    function isTeacher() {
      return request.auth != null;
    }

    // Function to check if teacher owns the document
    function isOwner(teacherId) {
      return isTeacher() && request.auth.uid == teacherId;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /exams/{examId} {
      // Teachers can CRUD their own exams
      allow read, write: if isTeacher() && (resource == null || resource.data.teacherId == request.auth.uid || request.resource.data.teacherId == request.auth.uid);
      // Students can read exams based on examCode query, this is secured in code by not letting them query all
      allow read: if true; 
    }

    match /questions/{questionId} {
      // Teachers can read/write their questions
      allow read, write: if isTeacher();
      // Students can read questions if they have an active attempt (hard to enforce strictly in rules without attempt id in question, so just allow read for now, handled by client logic)
      allow read: if true;
    }

    match /answerOptions/{optionId} {
      allow read, write: if isTeacher();
      // Students can read options, but should not see isCorrect
      allow read: if true;
    }

    match /studentAttempts/{attemptId} {
      // Teachers can read all attempts, and delete/update them
      allow read, write: if isTeacher();
      // Students can create their own attempts
      allow create: if true;
      // Students can read and update their own attempt if they have the ID
      allow read, update: if true;
    }

    match /studentAnswers/{answerId} {
      allow read, write: if isTeacher();
      allow create, read, update: if true;
    }

    match /examActivityLogs/{logId} {
      allow read, write: if isTeacher();
      allow create: if true;
    }
  }
}
